# ─── Solana Config ────────────────────────────────────────────────────────
# Network: devnet | mainnet-beta
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# RPC endpoint (use your own for mainnet — public devnet is rate limited)
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# Program ID — replace with deployed Anchor program address
NEXT_PUBLIC_PROGRAM_ID=11111111111111111111111111111111

# ─── Referee Keypair (server-side only, NEVER expose to client) ───────────
# Generate with: solana-keygen new --outfile referee.json
# Then paste the JSON array here:
# REFEREE_SECRET=[1,2,3,...,64]

# ─── Backend API (for score / detection) ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
